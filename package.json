{
  "name": "icia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "content:build": "node scripts/build-content.js",
    "prebuild": "node scripts/build-content.js && node scripts/build-publications.js && node scripts/download-images.js",
    "dev": "next dev",
    "build": "next build",
    "build:export": "NEXT_EXPORT=true next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "rm -rf .next out node_modules/.cache"
  },
  "dependencies": {
    "@notionhq/client": "^5.9.0",
    "framer-motion": "^12.34.0",
    "gray-matter": "^4.0.3",
    "maplibre-gl": "^5.24.0",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "vanilla-cookieconsent": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3"
  }
}
